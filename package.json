{
  "name": "@milkeyskills/sdk",
  "version": "0.1.5",
  "description": "Milkey skills infrastructure SDK for connecting multi-skill AI workflows into OpenAI, Anthropic, Gemini, and other AI stacks.",
  "keywords": [
    "milkey",
    "ai",
    "sdk",
    "skills",
    "skill infrastructure",
    "skills infrastructure",
    "multi-skill",
    "multi-skill infrastructure",
    "agent skills",
    "ai skills",
    "openai",
    "anthropic",
    "gemini",
    "tools",
    "agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashish200729/milkeyskills-sdk.git"
  },
  "homepage": "https://github.com/ashish200729/milkeyskills-sdk",
  "bugs": {
    "url": "https://github.com/ashish200729/milkeyskills-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "release:status": "npm view @milkeyskills/sdk --registry=https://registry.npmjs.org version",
    "release:check": "npm run check && npm run test && npm run build && npm pack --dry-run --cache ./.npm-cache",
    "release:publish": "npm publish --access public",
    "prepublishOnly": "npm run release:check",
    "example:anthropic-hosted": "tsx examples/anthropic-hosted.ts",
    "example:gemini-official": "tsx examples/gemini-official-sdk.ts",
    "example:gemini-interactions": "tsx examples/gemini-interactions-hosted.ts",
    "example:ai-sdk-inline": "tsx examples/ai-sdk-inline.ts",
    "example:openai-chat": "tsx examples/openai-chat-completions.ts",
    "example:openai-responses": "tsx examples/openai-responses.ts",
    "example:openai-inline": "tsx examples/openai-inline-loop.ts",
    "example:openai-chat:node": "node examples/openai-chat-completions.mjs"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.49",
    "@anthropic-ai/sdk": "^0.64.0",
    "@types/node": "^24.0.0",
    "@types/json-schema": "^7.0.15",
    "ai": "^6.0.141",
    "@google/genai": "^1.47.0",
    "openai": "^6.33.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.2.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
